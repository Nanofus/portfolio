---
import BaseLayout from "@layouts/BaseLayout.astro";
import VisualizationCanvas from "@components/VisualizationCanvas.svelte";
import { SITE_DESCRIPTION, SITE_TITLE } from "src/consts";

const permalink = Astro.site!.href;
---

<BaseLayout
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	permalink={permalink}
>
	<VisualizationCanvas client:load />

	<div class="content-container">
		<div class="home-copy">
			<h1>{SITE_TITLE}</h1>
			<p>{SITE_DESCRIPTION}</p>
			<p>
				My VR horror adventure <a
					href="https://store.steampowered.com/app/1570490/Perikoto/"
					target="_blank">Perikoto</a
				> is now out on Steam.
			</p>
		</div>
	</div>
</BaseLayout>

<style>
	.content-container {
		z-index: 1;
	}

	.home-copy h1 {
		font-family: var(--font-family-header), serif;
		font-weight: 400;
		margin-bottom: 0.5rem;
		line-height: 1.3;
		width: fit-content;
	}

	.home-copy p {
		width: fit-content;
	}

	@media (max-width: 1200px) {
		p {
			font-size: 1.2rem;
		}
	}

	@media (max-width: 800px) {
		.home-container {
			flex-direction: column;
			padding-left: 0;
		}

		.home-copy {
			flex: 0;
			padding-bottom: 2rem;
		}
	}
</style>
