---
import BaseLayout from "@layouts/BaseLayout.astro";
import Bio from "@components/Bio.astro";
import getPostData from "@utils/getPostData";
import { getCollection, getEntry, render } from "astro:content";
import formatDate from "@utils/formatDate";

export async function getStaticPaths() {
	const posts = await getCollection("writing");
	return posts.map((p) => ({
		params: { id: p.id },
		props: { post: p },
	}));
}

const { data } = Astro.props.post;
const entry = (await getEntry("writing", Astro.props.post.id))!;
const { Content, headings } = await render(entry);
const { title, description, pubDate, index } = data;
const { id, readingTime } = getPostData(Astro.props.post);
const permalink = `${Astro.site!.href}writing/${id}`;
const imageUrl = `${Astro.site!.href}writing/open-graph/${id}`;
---
  
<BaseLayout
	title={title}
	description={description || ""}
	permalink={permalink}
  imageUrl={imageUrl}
	current="writing"
>
	<div class="content-container">
		<header>
			<h1>{title}</h1>
			<p>№ {index} / {formatDate(pubDate)} / {readingTime}</p>
		</header>
		<article>
			<Content />
		</article>
		<Bio />
	</div>
</BaseLayout>

<style>
	article:after {
		position: relative;
		display: inline-block;
		text-align: center;
		left: 50%;
		font-size: 1.4rem;
		transform: translateX(-50%);
		content: "🍂";
	}

	header {
		text-align: center;
	}
	
	header h1 {
		font-size: 2.5rem;
		margin: 1rem 0 0;
	}

	header p {
		color: var(--background-color-subtle);
		font-family: var(--font-family-body), sans-serif;
	}
</style>
