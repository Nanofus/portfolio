---
import { SITE_TITLE } from "src/consts";

const { current = "" } = Astro.props;
---

<style></style>

<header>
	<nav>
		<a id="main-logo" class={current === "" ? "selected" : ""} href="/">
			<span>{SITE_TITLE}</span>
		</a>
		<span class="filler"></span>
		<a class="" target="_blank" href="https://store.steampowered.com/app/1570490/Perikoto/">
			Perikoto
		</a>
		<a class={current === "creations" ? "selected" : ""} href="/creations">
			Creations
		</a>
		<a class={current === "writing" ? "selected" : ""} href="/writing">
			Writing
		</a>
	</nav>
</header>

<style>
	header {
		display: flex;
		margin: 0 auto;
		width: 100%;
		border-bottom: 1px solid var(--background-color-subtle);
	}

	#main-logo span {
		background-position: left;
		background-size: contain;
		background-repeat: no-repeat;
	}

	nav {
		align-items: center;
		display: flex;
		flex: 1;
		font-family: var(--font-family-body), serif;
		font-weight: 500;
		justify-content: flex-end;
		margin-right: 1rem;
	}

	.filler {
		flex-grow: 1;
	}

	a {
		text-decoration: none;
		padding: 1rem;
		display: block;
		position: relative;
		text-align: center;
	}

	a:not(.selected) {
		filter: brightness(0.8);
	}

	a:not(.selected):hover {
		filter: brightness(1);
	}
</style>
